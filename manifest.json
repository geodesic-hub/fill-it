{
  "manifest_version": 3,
  "name": "Fill It",
  "description": "Auto-fill job applications with your saved profile",
  "version": "0.0.1",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Fill It"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ],
  "permissions": ["storage", "activeTab", "scripting"]
}
